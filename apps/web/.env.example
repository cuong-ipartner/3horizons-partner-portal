# Localhost demo (default) — seed + localStorage, no Supabase required
VITE_DATA_MODE=seed

# When schema is applied and Auth ready — see docs/supabase-setup.md
# VITE_DATA_MODE=supabase
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# Never put service_role in Vite env

# Public site origin (used later for auth redirects, OG, etc.)
VITE_SITE_URL=http://localhost:5173

# Production target
# VITE_SITE_URL=https://partners.3horizons.vn

# Nexus (Grok 4.5) — server-side only, never VITE_* / never commit real key
# Get key: https://console.x.ai
# Local: set in .env (Vite proxy /api/nexus)
# Cloudflare Pages: set secret XAI_API_KEY
# XAI_API_KEY=xai-...

# LinkedIn enrichment (real person public profile) — server only
# https://nubela.co/proxycurl/  (Person Profile API)
# PROXYCURL_API_KEY=
